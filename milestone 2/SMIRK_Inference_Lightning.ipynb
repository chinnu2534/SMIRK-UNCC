    "    zip_path = hf_hub_download(\n",
    "        repo_id='abhinavvelaga/smirk-assets',\n",
    "        filename='FLAME2020.zip',\n",
    "        repo_type='dataset',\n",
    "        token=HF_TOKEN,\n",
    "        local_dir=SMIRK_DIR,\n",
